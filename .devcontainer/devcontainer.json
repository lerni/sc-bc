{
  "name": "SomeConfig Issue Repro",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "Silverstripe CMS",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "sudo service mariadb start && sudo apache2ctl start 2>/dev/null || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "phpactor.vscode-phpactor"
      ]
    }
  }
}
